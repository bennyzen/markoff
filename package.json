{
  "name": "markoff",
  "private": true,
  "description": "Minimal distraction-free Markdown reader & editor",
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "bugs": "https://github.com/bennyzen/markoff/issues",
  "homepage": "https://github.com/bennyzen/markoff",
  "repository": "git+https://github.com/bennyzen/markoff.git",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder",
    "tauri": "tauri",
    "check": "biome check .",
    "fix": "biome check --write .",
    "fmt": "biome format --write ."
  },
  "build": {
    "appId": "com.bennyzen.markoff",
    "productName": "markoff",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "fileAssociations": [
      { "ext": "md", "mimeType": "text/markdown", "name": "Markdown Document" },
      { "ext": "markdown", "mimeType": "text/markdown", "name": "Markdown Document" },
      { "ext": "mdown", "mimeType": "text/markdown", "name": "Markdown Document" },
      { "ext": "mkd", "mimeType": "text/markdown", "name": "Markdown Document" },
      { "ext": "mkdn", "mimeType": "text/markdown", "name": "Markdown Document" }
    ],
    "linux": {
      "target": ["AppImage", "deb", "rpm"],
      "icon": "src-tauri/icons/icon.png",
      "category": "Office"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "src-tauri/icons/icon.png"
    },
    "win": {
      "target": ["nsis"],
      "icon": "src-tauri/icons/icon.ico"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.4",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "vite": "^7.1.11",
    "vite-plugin-pwa": "^1.1.0"
  },
  "dependencies": {
    "@codemirror/commands": "^6.6.2",
    "@codemirror/lang-markdown": "^6.2.5",
    "@codemirror/language": "^6.10.2",
    "@codemirror/language-data": "^6.4.1",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.34.2",
    "@fontsource/bungee": "^5.2.6",
    "@fontsource/fira-code": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/literata": "^5.2.8",
    "@fontsource/monaspace-argon": "^5.2.5",
    "@fontsource/monaspace-krypton": "^5.2.5",
    "@fontsource/public-sans": "^5.2.7",
    "@fontsource/source-serif-4": "^5.2.9",
    "@fontsource/space-grotesk": "^5.2.10",
    "@iconify-json/tabler": "^1.2.23",
    "@lezer/highlight": "^1.2.0",
    "highlight.js": "^11.9.0",
    "iconify-icon": "3.0.0",
    "marked": "^16.1.2",
    "morphdom": "^2.7.7"
  }
}
